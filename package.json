{
  "name": "printra",
  "private": true,
  "version": "0.1.5",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "dev:web": "pnpm --filter @printra/web dev",
    "dev:api": "pnpm --filter @printra/api dev",
    "dev:worker": "pnpm --filter @printra/worker dev",
    "build": "pnpm --filter @printra/web build",
    "build:web": "pnpm --filter @printra/web build",
    "start:api": "pnpm --filter @printra/api start",
    "start:worker": "pnpm --filter @printra/worker start"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msgpackr-extract",
      "sharp"
    ]
  }
}
