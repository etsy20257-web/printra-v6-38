{
  "manifest_version": 3,
  "name": "Printra Automatic Analysis",
  "version": "0.1.0",
  "description": "Capture Etsy listing and shop data for Printra Automatic Analysis.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://www.etsy.com/*",
    "http://localhost:4000/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Printra Automatic Analysis",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
